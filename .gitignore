# Reports (generated artifacts) — with exceptions for the committed
# evidence files that back the defects-caught / calibration / security docs.
# Each un-ignored directory must also un-ignore its own "*" before the
# specific file exception, since git won't descend into an ignored dir.
reports/*
!reports/semantic/
reports/semantic/*
!reports/semantic/results.json
!reports/defects/
reports/defects/*
!reports/defects/defects-caught.json
!reports/security/
reports/security/*
!reports/security/summary.json
!reports/security/summary.md
!reports/cost-summary.md
allure-report/
allure-results/
site/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node (for promptfoo later)
node_modules/
promptfoo/.cache/

# Jupyter (if used for exploration)
*.ipynb_checkpoints/

# Planning / internal docs (not for version control)
docs/*-roadmap.md
.claude/

# Misc
*.log
*.tmp
