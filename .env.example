# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# Which provider to use for runtime model calls.
# Options: zai | openrouter | together
# For zero-price hosted open-weight canary runs, use openrouter.
VERITY_PROVIDER=zai

# Model name — verify this slug matches your provider's model catalog before use.
# Changing this requires re-recording cassettes since model is part of the key.
# Suggested zero-price hosted OpenRouter canary:
# VERITY_PROVIDER=openrouter
# VERITY_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
VERITY_MODEL=glm-4.5

# ---------------------------------------------------------------------------
# API keys (only the one matching VERITY_PROVIDER is required at runtime)
# ---------------------------------------------------------------------------
VERITY_ZAI_API_KEY=your-zai-api-key-here
VERITY_OPENROUTER_API_KEY=your-openrouter-api-key-here
VERITY_TOGETHER_API_KEY=your-together-api-key-here

# ---------------------------------------------------------------------------
# API base overrides (leave blank to use built-in defaults)
# ---------------------------------------------------------------------------
# Verify the base URL for your provider before use — endpoints vary by account
# tier and API version. The values below are common defaults but may differ.
VERITY_ZAI_API_BASE=https://api.z.ai/v1
VERITY_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
VERITY_TOGETHER_API_BASE=https://api.together.xyz/v1

# ---------------------------------------------------------------------------
# Generation defaults
# ---------------------------------------------------------------------------
VERITY_TEMPERATURE=0.0
VERITY_MAX_TOKENS=2048
VERITY_TIMEOUT=60
VERITY_RETRIES=3
VERITY_SEMANTIC_SAMPLES=1

# ---------------------------------------------------------------------------
# Judge config (used in M3/M4 — set same as runtime model by default)
# ---------------------------------------------------------------------------
VERITY_JUDGE_MODEL=glm-4.5
VERITY_JUDGE_TEMPERATURE=0.0
VERITY_JUDGE_MAX_TOKENS=1024

# ---------------------------------------------------------------------------
# Tracing / Observability (M6 — optional; base install works without otel extra)
# ---------------------------------------------------------------------------
# Set to 1 to enable OpenTelemetry span collection. Default off (no overhead).
VERITY_TRACING=0

# Comma-separated exporters: console | file | otlp  (default: file)
VERITY_TRACE_EXPORTER=file

# Directory for file-exporter JSONL output (default: reports/traces)
VERITY_TRACE_DIR=reports/traces

# gRPC endpoint for OTLP exporter (e.g. local Phoenix or collector)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ---------------------------------------------------------------------------
# Retrieval config (M1)
# ---------------------------------------------------------------------------
VERITY_CORPUS_DIR=src/sut/corpus
VERITY_CHUNK_SIZE=160
VERITY_CHUNK_OVERLAP=30
VERITY_TOP_K=3
VERITY_EMBEDDING_MODEL=all-MiniLM-L6-v2
VERITY_PERSIST_DIR=.chroma
