# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# Which provider to use for runtime model calls.
# Options: zai | openrouter | together | nvidia | google
# zai     = the default used to record every committed cassette in this repo.
# nvidia  = NVIDIA NIM (build.nvidia.com) — no daily request cap, ~40 RPM free.
# google  = Google AI Studio (Gemini)     — 1,500 requests/day free tier.
#
# NOTE: Tier-1/Tier-3 hermetic tests pin provider=zai/model=glm-4.5 internally
# and never read these values, so changing them below only affects live runs
# (`make smoke`, `make demo`, `make eval-semantic`, `make redteam-live`).
VERITY_PROVIDER=zai

# Model name — verify this slug matches your provider's model catalog before use.
# Changing this requires re-recording cassettes since model is part of the key.
#
# Zero-price alternative for live smoke-testing without a Z.ai key:
# VERITY_PROVIDER=openrouter
# VERITY_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
VERITY_MODEL=glm-4.5

# ---------------------------------------------------------------------------
# API keys (only the one matching VERITY_PROVIDER is required at runtime)
# ---------------------------------------------------------------------------
VERITY_ZAI_API_KEY=your-zai-api-key-here
VERITY_OPENROUTER_API_KEY=your-openrouter-api-key-here
VERITY_TOGETHER_API_KEY=your-together-api-key-here
VERITY_NVIDIA_API_KEY=your-nvidia-nim-api-key-here
VERITY_GOOGLE_API_KEY=your-google-ai-studio-api-key-here

# ---------------------------------------------------------------------------
# API base overrides (leave blank to use built-in defaults)
# ---------------------------------------------------------------------------
# Verify the base URL for your provider before use — endpoints vary by account
# tier and API version. The values below are common defaults but may differ.
VERITY_ZAI_API_BASE=https://api.z.ai/v1
VERITY_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
VERITY_TOGETHER_API_BASE=https://api.together.xyz/v1
VERITY_NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
# Google's litellm handler resolves its own endpoint; leave blank unless you
# have a specific reason to override it (e.g. Vertex AI Gemini instead of AI Studio).
VERITY_GOOGLE_API_BASE=

# ---------------------------------------------------------------------------
# Generation defaults
# ---------------------------------------------------------------------------
VERITY_TEMPERATURE=0.0
VERITY_MAX_TOKENS=2048
VERITY_TIMEOUT=60
VERITY_RETRIES=3

# N=1 keeps local/push semantic runs fast and cheap; the statistical
# aggregation in verity/statistics.py only becomes meaningful at N>1.
# The nightly scheduled run sets N=5 (see semantic-eval.yml) to actually
# exercise the distribution-over-N machinery. Raise this locally if you
# want to see pass_rate/stdev vary across samples.
VERITY_SEMANTIC_SAMPLES=1

# ---------------------------------------------------------------------------
# Judge config (set same as runtime model by default)
# ---------------------------------------------------------------------------
# VERITY_JUDGE_PROVIDER is optional and defaults to VERITY_PROVIDER when unset.
# Set it to a different provider than the SUT model to avoid sharing one
# provider's rate limit between SUT calls and judge (RAGAS) calls — this
# matters on free tiers like NVIDIA NIM's ~40 RPM cap.
VERITY_JUDGE_PROVIDER=zai
VERITY_JUDGE_MODEL=glm-4.5
VERITY_JUDGE_TEMPERATURE=0.0
VERITY_JUDGE_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# Tracing / Observability (optional; base install works without the otel extra)
# ---------------------------------------------------------------------------
# Set to 1 to enable OpenTelemetry span collection. Default off (no overhead).
VERITY_TRACING=0

# Comma-separated exporters: console | file | otlp  (default: file)
VERITY_TRACE_EXPORTER=file

# Directory for file-exporter JSONL output (default: reports/traces)
VERITY_TRACE_DIR=reports/traces

# gRPC endpoint for OTLP exporter (e.g. local Phoenix or collector)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional member-token mapping for member-scoped demo access. Disabled unless
# VERITY_MEMBER_AUTH_REQUIRED=true. Example value format:
# VERITY_MEMBER_TOKENS={"MBR-001":"token-1","MBR-002":"token-2"}
VERITY_MEMBER_AUTH_REQUIRED=false
# VERITY_MEMBER_TOKENS=

# ---------------------------------------------------------------------------
# Retrieval config
# ---------------------------------------------------------------------------
VERITY_CORPUS_DIR=src/sut/corpus
VERITY_CHUNK_SIZE=160
VERITY_CHUNK_OVERLAP=30
VERITY_TOP_K=3
VERITY_PERSIST_DIR=.chroma
